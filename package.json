{
  "name": "oshu-work-telegram-mini-app",
  "version": "14.0.1",
  "type": "module",
  "description": "oshu://work - Telegram Mini App для поиска вакансий с real-time функциями",
  "scripts": {
    "dev": "vite --port 4176 --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --port 4176 --host 0.0.0.0",
    "build:dev": "vite build --mode development",
    "build:prod": "vite build --mode production",
    "serve": "vite preview --port 4173",
    "clean": "rm -rf dist",
    "mock-ws": "node mock-websocket-server.js",
    "dev:full": "concurrently \"npm run mock-ws\" \"npm run dev\""
  },
  "devDependencies": {
    "vite": "^5.4.3",
    "terser": "^5.31.6",
    "concurrently": "^8.2.2",
    "express": "^4.19.2",
    "socket.io": "^4.7.5",
    "cors": "^2.8.5"
  },
  "dependencies": {},
  "keywords": ["telegram", "mini-app", "job-parser", "vite"],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "your-repo-url"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}